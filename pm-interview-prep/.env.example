# PM Behavioral Interview Prep — environment template
# Copy to `.env` and fill in. The `.env` file is gitignored.

# Which LLM provider to use. One of: gemini, mock
LLM_PROVIDER=mock

# Required when LLM_PROVIDER=gemini.
# Get a free key (no credit card) at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional model overrides.
# Free-tier-friendly defaults. On a paid plan, switch the strong model to
# gemini-2.5-pro for noticeably better evaluation quality.
GEMINI_STRONG_MODEL=gemini-2.5-flash
GEMINI_CHEAP_MODEL=gemini-2.5-flash-lite

# Per-model rate limit (req/min). Gemini free tier = 10. Bump to ~60 on paid.
GEMINI_RPM=10

# Session shape
MAX_FOLLOWUPS_PER_QUESTION=2
MAX_QUESTIONS_PER_SESSION=5
MAX_ANSWER_CHARS=4000
